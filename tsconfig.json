{
  "compilerOptions": {
    "target": "ES2018",
    "module": "commonjs",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["shared/*"]
    },
    "typeRoots": [
      "./server/types",
      "./node_modules/@types"
    ]
  },
  "include": ["server/**/*", "shared/**/*", "server/types/**/*"],
  "exclude": ["node_modules"]
}
