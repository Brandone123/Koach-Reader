{
  "expo": {
    "name": "Koach Reader",
    "slug": "koach-reader",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6200ee"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.koach.reader",
      "associatedDomains": [
        "applinks:koachreader.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6200ee"
      },
      "package": "com.koach.reader",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "koachreader",
              "host": "reset-password"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "scheme": "koachreader",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false,
            "enableProguardInReleaseBuilds": false,
            "extraProguardRules": "-keep class com.swmansion.reanimated.** { *; }"
          },
          "ios": {
            "newArchEnabled": false,
            "flipper": false
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7609ec84-5b76-49f6-914c-319df8276ca2"
      }
    },
    "owner": "brandone_1213"
  }
}
